PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017
DB_NAME=todo-app
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_REFRESH_SECRET=another-long-random-string-for-refresh-tokens-32
JWT_ACCESS_EXPIRES=24h
JWT_REFRESH_EXPIRES=7d

# Optional: Mocha integration tests — use real MongoDB if MongoMemoryServer times out on your PC
# TEST_MONGO_URI=mongodb://127.0.0.1:27017
# TEST_DB_NAME=todo_integration_test
